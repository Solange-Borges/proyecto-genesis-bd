public class Recurso {

    private String titulo;
    private String edad;

    public Recurso(String titulo, String edad) {
        this.titulo = titulo;
        this.edad = edad;
    }

    public String getTitulo() {
        return titulo;
    }

    public String getEdad() {
        return edad;
    }
}

